<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Chá de Casa Nova</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500&display=swap" rel="stylesheet">

<style>

body{
font-family:Poppins;
background:linear-gradient(120deg,#fdfbfb,#ebedee);
margin:0;
text-align:center;
}

.container{
max-width:700px;
margin:auto;
margin-top:60px;
background:white;
padding:40px;
border-radius:20px;
box-shadow:0 20px 40px rgba(0,0,0,0.08);
}

h1{
font-weight:500;
}

input{
padding:12px;
width:80%;
border-radius:10px;
border:1px solid #ddd;
font-size:16px;
}

button{
background:#ff6f61;
color:white;
border:none;
padding:12px 25px;
border-radius:10px;
font-size:16px;
margin-top:20px;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:#ff4b3e;
}

.grid{
margin-top:20px;
display:grid;
grid-template-columns:1fr 1fr;
gap:12px;
}

.item{
padding:15px;
border-radius:12px;
border:1px solid #eee;
cursor:pointer;
transition:0.2s;
}

.item:hover{
background:#fafafa;
}

.selecionado{
background:#e6ffe6;
border:2px solid #3bc73b;
}

.indisponivel{
background:#ddd;
color:#888;
cursor:not-allowed;
}

.hidden{
display:none;
}

.listaAdmin{
text-align:left;
margin-top:20px;
}

</style>

</head>
<body>

<div class="container">

<h1>🏠 Chá de Casa Nova</h1>

<div id="etapa1">

<p>Digite seu nome</p>

<input id="nome">

<br>

<button onclick="continuar()">Continuar</button>

</div>

<div id="etapa2" class="hidden">

<h2>Escolha um presente</h2>

<div id="lista" class="grid"></div>

<button onclick="confirmar()">Confirmar</button>

</div>

<div id="etapa3" class="hidden">

<h2>☑️ Obrigado!</h2>

<p>
Obrigado por participar desse momento especial da nossa vida.
Seu carinho significa muito para nós.
</p>

<b>Inara e Pedro</b>

<br><br>

<button onclick="ver()">Ver escolhas</button>

<div id="resultado"></div>

</div>

<div id="admin" class="hidden">

<h2>Painel Administrador</h2>

<div id="listaAdmin" class="listaAdmin"></div>

<button onclick="resetar()">Reiniciar lista</button>

</div>

</div>

<script>

let url=new URLSearchParams(window.location.search)

let admin=url.get("admin")

let nome=""
let escolha=null

let itens=[

"🍳 Panela",
"🍽️ Jogo de Pratos",
"🥤 Copos",
"🥪 Sanduicheira",
"🍲 Frigideira",
"🍴 Talheres",
"🧻 Toalha",
"🥣 Tigelas"

]

let escolhidos=JSON.parse(localStorage.getItem("presentes"))||{}

if(admin=="1234"){

document.getElementById("etapa1").classList.add("hidden")
document.getElementById("admin").classList.remove("hidden")

mostrarAdmin()

}

function continuar(){

nome=document.getElementById("nome").value

if(nome==""){
alert("Digite seu nome")
return
}

document.getElementById("etapa1").classList.add("hidden")
document.getElementById("etapa2").classList.remove("hidden")

mostrar()

}

function mostrar(){

let lista=document.getElementById("lista")

lista.innerHTML=""

itens.forEach(item=>{

let div=document.createElement("div")

div.className="item"

div.innerText=item

if(escolhidos[item]){

div.classList.add("indisponivel")

}else{

div.onclick=()=>{

document.querySelectorAll(".item").forEach(i=>i.classList.remove("selecionado"))

div.classList.add("selecionado")

escolha=item

}

}

lista.appendChild(div)

})

}

function confirmar(){

if(!escolha){

alert("Escolha um presente")

return

}

escolhidos[escolha]=nome

localStorage.setItem("presentes",JSON.stringify(escolhidos))

document.getElementById("etapa2").classList.add("hidden")

document.getElementById("etapa3").classList.remove("hidden")

}

function ver(){

let r=document.getElementById("resultado")

r.innerHTML="<h3>Escolhas</h3>"

for(let item in escolhidos){

r.innerHTML+=item+" - "+escolhidos[item]+"<br>"

}

}

function mostrarAdmin(){

let a=document.getElementById("listaAdmin")

a.innerHTML=""

for(let item in escolhidos){

a.innerHTML+=item+" - "+escolhidos[item]+"<br>"

}

}

function resetar(){

if(confirm("Tem certeza que deseja apagar tudo?")){

localStorage.removeItem("presentes")

location.reload()

}

}

</script>

</body>
</html>
